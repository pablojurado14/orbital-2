generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ClinicSettings {
  id                     Int                   @id @default(1)
  name                   String                @default("Mi Clínica Dental")
  zonaHoraria            String                @default("Europe/Madrid")
  pesosKpi               Json?
  politicaAutonomia      Json?
  umbralDisparoProactivo Float?
  schedules              DaySchedule[]
  gabinetes              Gabinete[]
  dentists               Dentist[]
  treatmentTypes         TreatmentType[]
  patients               Patient[]
  appointments           Appointment[]
  runtimeStates          RuntimeState[]
  equipment              Equipment[]
  procedureActivations   ProcedureActivation[]
  constraintRules        ConstraintRule[]
  waitlistEntries        WaitlistEntry[]
  rejectedCandidates     RejectedCandidate[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
}

model DaySchedule {
  id             Int            @id @default(autoincrement())
  dayOfWeek      Int
  isOpen         Boolean        @default(true)
  morningOpen    String?
  morningClose   String?
  afternoonOpen  String?
  afternoonClose String?
  clinicId       Int
  clinic         ClinicSettings @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, dayOfWeek])
}

model Gabinete {
  id           Int             @id @default(autoincrement())
  name         String          @unique
  description  String?
  active       Boolean         @default(true)
  clinicId     Int?
  clinic       ClinicSettings? @relation(fields: [clinicId], references: [id])
  appointments Appointment[]
  preferredBy  Patient[]       @relation("PatientPreferredGabinete")
  equipment    EquipmentRoom[]

  @@index([clinicId])
}

model Dentist {
  id           Int             @id @default(autoincrement())
  name         String
  specialty    String?
  active       Boolean         @default(true)
  capabilities Json?
  workSchedule Json?
  hourlyCost   Float?
  clinicId     Int?
  clinic       ClinicSettings? @relation(fields: [clinicId], references: [id])
  appointments Appointment[]
  preferredBy  Patient[]       @relation("PatientPreferredDentist")

  @@index([clinicId])
}

model TreatmentType {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  duration        Int
  price           Float?
  currency        String          @default("EUR")
  active          Boolean         @default(true)
  clinicId        Int?
  clinic          ClinicSettings? @relation(fields: [clinicId], references: [id])
  appointments    Appointment[]
  waitlistEntries WaitlistEntry[]

  @@index([clinicId])
}

model Patient {
  id                    Int             @id @default(autoincrement())
  name                  String
  phone                 String?
  email                 String?
  notes                 String?
  createdAt             DateTime        @default(now())
  active                Boolean         @default(true)
  priority              Int             @default(1)
  availableNow          Boolean         @default(true)
  easeScore             Int             @default(5)
  preferredGabineteId   Int?
  preferredDentistId    Int?
  noShowScore           Float?
  latenessMeanMinutes   Float?
  latenessStdDevMinutes Float?
  acceptAdviceScore     Float?
  clinicId              Int?
  clinic                ClinicSettings? @relation(fields: [clinicId], references: [id])
  preferredGabinete     Gabinete?       @relation("PatientPreferredGabinete", fields: [preferredGabineteId], references: [id])
  preferredDentist      Dentist?        @relation("PatientPreferredDentist", fields: [preferredDentistId], references: [id])
  appointments          Appointment[]
  waitlistEntries       WaitlistEntry[]

  @@index([clinicId])
}

model Appointment {
  id              Int                    @id @default(autoincrement())
  startTime       String
  date            DateTime
  duration        Int
  // status: uno de "scheduled" | "confirmed" | "in_waiting_room" | "in_progress"
  //         | "completed" | "cancelled" | "no_show". Validacion en TS via
  //         AppointmentRuntimeStatus en lib/core/types.ts.
  status          String                 @default("scheduled")
  value           Float?
  currency        String                 @default("EUR")
  notes           String?
  // Slots reales (rellenados al iniciar/terminar la cita). NULL hasta entonces.
  actualStartTime DateTime?
  actualEndTime   DateTime?
  patientId       Int
  patient         Patient                @relation(fields: [patientId], references: [id])
  dentistId       Int
  dentist         Dentist                @relation(fields: [dentistId], references: [id])
  gabineteId      Int
  gabinete        Gabinete               @relation(fields: [gabineteId], references: [id])
  treatmentTypeId Int
  treatmentType   TreatmentType          @relation(fields: [treatmentTypeId], references: [id])
  clinicId        Int?
  clinic          ClinicSettings?        @relation(fields: [clinicId], references: [id])
  reservedEquipment AppointmentEquipment[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([clinicId, date])
  @@index([date])
  @@index([gabineteId, date])
  @@index([patientId])
}

model RuntimeState {
  id                 Int             @id
  suggestionDecision String          @default("pending")
  clinicId           Int?
  clinic             ClinicSettings? @relation(fields: [clinicId], references: [id])

  @@index([clinicId])
}

// ============================================================
// Catálogo maestro (Sesión 11B)
// ============================================================

model Procedure {
  id                               Int                   @id @default(autoincrement())
  code                             String
  name                             String
  category                         String
  subcategory                      String?
  requiresProfessionalCapabilities Json
  requiresRoomCapabilities         Json
  requiresEquipment                Json
  requiresAuxiliary                Boolean               @default(false)
  auxiliaryCapabilities            Json?
  referenceDurationMean            Float
  referenceDurationStdDev          Float
  referenceDurationP10             Float
  referenceDurationP50             Float
  referenceDurationP90             Float
  clinicalDependencies             Json?
  version                          Int                   @default(1)
  active                           Boolean               @default(true)
  activations                      ProcedureActivation[]
  waitlistEntries                  WaitlistEntry[]
  createdAt                        DateTime              @default(now())
  updatedAt                        DateTime              @updatedAt

  @@unique([code, version])
  @@index([category])
  @@index([active])
}

model Equipment {
  id                   Int                    @id @default(autoincrement())
  clinicId             Int
  type                 String
  name                 String
  modality             String
  setupTimeMs          Int?
  cleanupTimeMs        Int?
  sterilizationCycleMs Int?
  active               Boolean                @default(true)
  clinic               ClinicSettings         @relation(fields: [clinicId], references: [id])
  compatibleRooms      EquipmentRoom[]
  appointmentReservations AppointmentEquipment[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([clinicId])
  @@index([clinicId, type])
  @@index([clinicId, active])
}

model EquipmentRoom {
  equipmentId Int
  gabineteId  Int
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  gabinete    Gabinete  @relation(fields: [gabineteId], references: [id], onDelete: Cascade)

  @@id([equipmentId, gabineteId])
  @@index([gabineteId])
}

model ProcedureActivation {
  id                    Int            @id @default(autoincrement())
  clinicId              Int
  procedureId           Int
  active                Boolean        @default(true)
  price                 Float?
  currency              String         @default("EUR")
  learnedDurationMean   Float
  learnedDurationStdDev Float
  learnedDurationP10    Float
  learnedDurationP50    Float
  learnedDurationP90    Float
  localRestrictions     Json?
  clinic                ClinicSettings @relation(fields: [clinicId], references: [id])
  procedure             Procedure      @relation(fields: [procedureId], references: [id])
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([clinicId, procedureId])
  @@index([clinicId])
  @@index([procedureId])
  @@index([clinicId, active])
}

// ============================================================
// Runtime extendido + restricciones + waitlist (Sesión 11D)
// ============================================================

// Reservas de equipamiento por cita. Una cita puede reservar varios equipos
// en ventanas de tiempo distintas dentro de su duracion. Indexable por equipo+rango
// para deteccion de conflictos en C2 Validator (Sesion 13).
model AppointmentEquipment {
  appointmentId    Int
  equipmentId      Int
  reservedFromMs   BigInt
  reservedToMs     BigInt
  appointment      Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  equipment        Equipment   @relation(fields: [equipmentId], references: [id], onDelete: Restrict)

  @@id([appointmentId, equipmentId, reservedFromMs])
  @@index([equipmentId, reservedFromMs])
  @@index([appointmentId])
}

// Restricciones tipadas por clinica. code y hardness son strings con set documentado:
//   code: uno de los 12 ConstraintCode definidos en lib/core/types.ts
//   hardness: "hard" | "soft"
// Validacion en TS via tipos del clean core. Tabla arranca vacia (Sesion 11D);
// se poblara cuando una clinica configure restricciones especificas.
model ConstraintRule {
  id                 Int            @id @default(autoincrement())
  clinicId           Int
  code               String
  hardness           String
  referencedEntities Json
  parameters         Json
  active             Boolean        @default(true)
  priority           Int?
  clinic             ClinicSettings @relation(fields: [clinicId], references: [id])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([clinicId])
  @@index([clinicId, active])
  @@index([clinicId, code])
}

// Waitlist como entidad de primera clase, separada de Patient.waiting*.
// desiredProcedureId y desiredTreatmentTypeId coexisten hasta Sesion 18:
//   - 11D backfill solo rellena desiredTreatmentTypeId (motor v7.3 vivo).
//   - Sesion 18 mapea a desiredProcedureId y deprecia el otro.
// Deuda: WAITLIST-DUAL-COLUMNS-S18 / WAITLIST-RESYNC-S18.
model WaitlistEntry {
  id                      Int            @id @default(autoincrement())
  clinicId                Int
  patientId               Int
  desiredProcedureId      Int?
  desiredTreatmentTypeId  Int?
  durationSlots           Int
  value                   Float
  currency                String         @default("EUR")
  priority                Int            @default(1)
  availableNow            Boolean        @default(true)
  easeScore               Int            @default(5)
  urgency                 Int?           @default(3)
  availabilityWindow      Json?
  preferredContactChannel String?
  createdAt               DateTime       @default(now())
  expiresAt               DateTime?
  clinic                  ClinicSettings @relation(fields: [clinicId], references: [id])
  patient                 Patient        @relation(fields: [patientId], references: [id])
  desiredProcedure        Procedure?     @relation(fields: [desiredProcedureId], references: [id])
  desiredTreatmentType    TreatmentType? @relation(fields: [desiredTreatmentTypeId], references: [id])

  @@index([clinicId])
  @@index([clinicId, patientId])
  @@index([clinicId, availableNow])
  @@index([patientId])
  @@index([desiredProcedureId])
  @@index([desiredTreatmentTypeId])
}

// ============================================================
// Iteración de candidatas (Sesión 18.6)
// ============================================================

// Candidatas de waitlist que el operador ha rechazado para un hueco
// concreto (gap = Appointment cancelado). El adapter las filtra del
// waitlist context antes de pasar al Coordinator. Se purgan al cambiar
// de día (medianoche Madrid) por housekeeping en route.ts.
//
// Decisión rectora 11 (S18.6): el gap se identifica por el Appointment.id
// del cancelado (como string). Misma referencia que entra al cancellation
// event. Cuando S20+ implemente multi-gap (deuda PROACTIVE-SWEEP-MULTI-GAP-V1),
// cada gap individual seguirá teniendo su Appointment.id.
//
// gapEventId y waitingCandidateId son strings (no FKs) porque:
//   - El clean core opera con IDs opacos (ResourceId/EventId).
//   - Una FK a Appointment forzaría onDelete cascade que no queremos
//     (si se borra el cancelado, el rejected sigue siendo histórico).
//   - waitingCandidateId apunta a WaitlistEntry.id pero stringificado;
//     mismo razonamiento de no-FK.
model RejectedCandidate {
  id                 Int            @id @default(autoincrement())
  clinicId           Int
  gapEventId         String
  waitingCandidateId String
  rejectedAt         DateTime       @default(now())
  clinic             ClinicSettings @relation(fields: [clinicId], references: [id])

  @@unique([clinicId, gapEventId, waitingCandidateId])
  @@index([clinicId, gapEventId])
  @@index([clinicId, rejectedAt])
}